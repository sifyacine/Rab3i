# Rab3i — local environment (example)
# Copy to `.env` and fill values from Supabase project settings.

# App base URL used for Supabase auth redirect URLs (signup, password reset).
# Set this for Netlify/production deployments (e.g. https://your-app.netlify.app).
# Falls back to window.location.origin when not set.
VITE_APP_URL=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
